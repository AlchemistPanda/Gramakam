rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Book festival collections (public read/write for POS)
    match /bookfest/{document=**} { allow read, write: if true; }
    match /bookfest_books/{document=**} { allow read, write: if true; }
    match /bookfest_bills/{document=**} { allow read, write: if true; }
    match /bookfest_publishers/{document=**} { allow read, write: if true; }
    match /bookfest_requests/{document=**} { allow read, write: if true; }
    match /bookfest_returns/{document=**} { allow read, write: if true; }
    
    // Website collections (public read, authenticated write)
    match /posts/{document=**} { allow read: if true; allow write: if true; }
    match /gallery/{document=**} { allow read: if true; allow write: if true; }
    match /contacts/{document=**} { allow read, write: if true; }
    match /prebooks/{document=**} { allow read, write: if true; }
    match /merch_orders/{document=**} { allow read, write: if true; }
    match /merch_stock/{document=**} { allow read, write: if true; }
    match /game_scores/{document=**} { allow read, write: if true; }
    match /upi_payments/{document=**} { allow read, write: if true; }
    match /awards/{document=**} { allow read, write: if true; }
    match /media_items/{document=**} { allow read, write: if true; }
    match /workshop_gallery/{document=**} { allow read, write: if true; }
    match /festival_schedule/{document=**} { allow read, write: if true; }
    match /config/{document=**} { allow read: if true; allow write: if true; }
  }
}
